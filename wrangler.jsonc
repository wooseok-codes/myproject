{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myproject",
  "compatibility_date": "2026-03-11",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "myproject-production",
      "database_id": "placeholder-will-be-replaced-after-create"
    }
  ]
}